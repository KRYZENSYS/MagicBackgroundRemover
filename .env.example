# Bot
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
BOT_USERNAME=@MagicBgBot
BOT_NAME=MagicBackground Remover Pro

# Admins (comma-separated Telegram IDs)
ADMIN_IDS=123456789

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
DATABASE_BACKUP_DIR=./data/backups

# Redis (optional - falls back to in-memory)
REDIS_URL=redis://localhost:6379/0
USE_REDIS=false

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=CHANGE_ME_TO_LONG_RANDOM_STRING
API_CORS_ORIGINS=*

# Limits
FREE_DAILY_LIMIT=5
PREMIUM_DAILY_LIMIT=100
VIP_DAILY_LIMIT=1000
TRIAL_DAYS=3
MAX_FILE_SIZE_MB=20
BATCH_MAX_FILES=10

# AI
REMBG_MODEL=u2net
UPSCALER_MODEL=RealESRGAN_x4plus
ENABLE_GFPGAN=true
ENABLE_ENHANCEMENT=true

# Storage
STORAGE_DIR=./storage
TEMP_DIR=./tmp
CACHE_DIR=./cache
CACHE_TTL=3600
LOG_DIR=./logs

# Required Channels (comma-separated)
REQUIRED_CHANNELS=@your_channel

# Payments
ENABLE_STARS=true
ENABLE_CLICK=false
ENABLE_PAYME=false
ENABLE_STRIPE=false
ENABLE_PAYPAL=false
ENABLE_CRYPTO=false
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
CRYPTO_WALLET_BTC=
CRYPTO_WALLET_ETH=
CRYPTO_WALLET_USDT=

# Referral
REFERRAL_BONUS_FREE_DAYS=3
REFERRAL_BONUS_PREMIUM_PERCENT=20

# Premium Plans (in stars / cents)
PRICE_MONTHLY_STARS=500
PRICE_YEARLY_STARS=5000
PRICE_LIFETIME_STARS=15000
PRICE_MONTHLY_USD=499
PRICE_YEARLY_USD=4999
PRICE_LIFETIME_USD=14999

# Sentry (optional)
SENTRY_DSN=

# Environment
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO